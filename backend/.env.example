NODE_ENV=development
APP_PORT=6001
APP_NAME="NestJS API"
API_PREFIX=api
APP_FALLBACK_LANGUAGE=en
APP_HEADER_LANGUAGE=x-custom-lang
FRONTEND_DOMAIN=http://localhost:3000
BACKEND_DOMAIN=http://localhost:6001
ENTRA_REDIRECT_URI=http://localhost:6001/api/v1/auth/entra/callback

DATABASE_TYPE=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5435
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=m123
DATABASE_NAME=cybsec_pmo
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=100
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false
DATABASE_CA=
DATABASE_KEY=
DATABASE_CERT=
DATABASE_URL=postgresql://postgres:m123@localhost:5435/cybsec_pmo?schema=public

FILE_DRIVER=local

# Maildev configuration
MAIL_HOST=maildev
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_IGNORE_TLS=true
MAIL_SECURE=false
MAIL_REQUIRE_TLS=false
MAIL_DEFAULT_EMAIL=noreply@example.com
MAIL_DEFAULT_NAME=Api
MAIL_CLIENT_PORT=1080

AUTH_JWT_SECRET=secret-key-change-in-prod
AUTH_JWT_TOKEN_EXPIRES_IN=15m
AUTH_REFRESH_SECRET=refresh-key-change-in-prod
AUTH_REFRESH_TOKEN_EXPIRES_IN=3650d
AUTH_FORGOT_SECRET=forgot-key-change-in-prod
AUTH_FORGOT_TOKEN_EXPIRES_IN=30m
AUTH_CONFIRM_EMAIL_SECRET=confirm-key-change-in-prod
AUTH_CONFIRM_EMAIL_TOKEN_EXPIRES_IN=1d

# Microsoft Entra ID (Azure AD) SSO Keys
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

WORKER_HOST=redis://localhost:6378/1

AUTH_LOGIN_MAX_FAILURES=5
AUTH_LOGIN_FAILURE_WINDOW_SEC=900
AUTH_LOGIN_LOCKOUT_SEC=1800
AUTH_LOGIN_RATE_LIMIT=10
AUTH_LOGIN_RATE_WINDOW_SEC=60
AUTH_LOGIN_ALERT_THRESHOLD=5

AUTH_SESSION_IDLE_SEC=9000
AUTH_SESSION_WARNING_BEFORE_SEC=600

SECURITY_ALERTS_ENABLED=false
SECURITY_ALERT_EMAIL=info@yourdomain.com

# Break-glass emergency access
BREAK_GLASS_ENABLED=true
AUTH_BREAK_GLASS_TTL=4h
BREAK_GLASS_EMERGENCY_SECRET=cybsec-emergency-vault-secret-2026
