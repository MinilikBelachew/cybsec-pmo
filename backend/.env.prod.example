# Copy to backend/.env.prod on the server before deploy:
#   cp backend/.env.prod.example backend/.env.prod
# Then edit secrets and domains.

NODE_ENV=production
APP_PORT=3000
APP_NAME="Cybsec PMO API"
API_PREFIX=api
APP_FALLBACK_LANGUAGE=en
APP_HEADER_LANGUAGE=x-custom-lang

# Production domains — update to your real URLs
FRONTEND_DOMAIN=https://cybsec.addisanalytics.com
BACKEND_DOMAIN=https://cybsec.addisanalytics.com
ENTRA_REDIRECT_URI=https://cybsec.addisanalytics.com/api/v1/auth/entra/callback

DATABASE_TYPE=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USERNAME=root
DATABASE_PASSWORD=secret123
DATABASE_NAME=cybersec
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=100
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false
DATABASE_CA=
DATABASE_KEY=
DATABASE_CERT=
DATABASE_URL=postgresql://root:secret123@postgres:5432/cybersec?schema=public

FILE_DRIVER=local

# Mail (production SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_IGNORE_TLS=false
MAIL_SECURE=false
MAIL_REQUIRE_TLS=true
MAIL_DEFAULT_EMAIL=noreply@yourdomain.com
MAIL_DEFAULT_NAME=Cybsec PMO

# Auth — generate secure random values for production
AUTH_JWT_SECRET=change-me-to-a-secure-random-key
AUTH_JWT_TOKEN_EXPIRES_IN=15m
AUTH_REFRESH_SECRET=change-me-to-another-secure-random-key
AUTH_REFRESH_TOKEN_EXPIRES_IN=3650d
AUTH_FORGOT_SECRET=change-me-to-forgot-secure-random-key
AUTH_FORGOT_TOKEN_EXPIRES_IN=30m
AUTH_CONFIRM_EMAIL_SECRET=change-me-to-confirm-secure-random-key
AUTH_CONFIRM_EMAIL_TOKEN_EXPIRES_IN=1d

# Microsoft Entra ID (Azure AD) SSO
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

WORKER_HOST=redis://redis:6379/1

# MPP import (MPXJ microservice — set in docker-compose.prod.yml too)
MPXJ_SERVICE_URL=http://mpxj-service:8080
MPP_IMPORT_STORAGE_DIR=/tmp/mpp-imports
MPP_IMPORT_MAX_FILE_SIZE_BYTES=52428800

AUTH_LOGIN_MAX_FAILURES=5
AUTH_LOGIN_FAILURE_WINDOW_SEC=900
AUTH_LOGIN_LOCKOUT_SEC=1800
AUTH_LOGIN_RATE_LIMIT=10
AUTH_LOGIN_RATE_WINDOW_SEC=60
AUTH_LOGIN_ALERT_THRESHOLD=5

AUTH_SESSION_IDLE_SEC=9000
AUTH_SESSION_WARNING_BEFORE_SEC=600

SECURITY_ALERTS_ENABLED=true
SECURITY_ALERT_EMAIL=info@yourdomain.com

BREAK_GLASS_ENABLED=true
AUTH_BREAK_GLASS_TTL=4h
BREAK_GLASS_EMERGENCY_SECRET=change-me-to-your-break-glass-secret
