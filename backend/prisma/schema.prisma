  @@index([primaryEmail], map: "idx_customers_email")
  @@index([zohoContactId], map: "idx_customers_zoho")
  @@index([status], map: "idx_customers_status")
  @@index([type], map: "idx_customers_type")
  @@map("customers")
}

model CustomerContact {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId      String   @map("customer_id") @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  firstName       String   @map("first_name") @db.VarChar(100)
  lastName        String   @map("last_name") @db.VarChar(100)
  jobTitle        String?  @map("job_title") @db.VarChar(100)
  email           String   @db.VarChar(255)
  phone           String?  @db.VarChar(50)
  isPrimary       Boolean  @default(false) @map("is_primary")
  receivesReports Boolean  @default(false) @map("receives_reports")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  customer Customer @relation(fields: [customerId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])

  reportScheduleRecipients ReportScheduleRecipient[]

  @@index([customerId], map: "idx_customer_contacts_customer")
  @@index([userId], map: "idx_customer_contacts_user")
  @@index([email], map: "idx_customer_contacts_email")
  @@map("customer_contacts")
}

model Vendor {
  id                    String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type                  PartyType
  companyName           String?    @map("company_name") @db.VarChar(255)
  registrationNumber    String?    @map("registration_number") @db.VarChar(100)
  firstName             String?    @map("first_name") @db.VarChar(100)
  lastName              String?    @map("last_name") @db.VarChar(100)
  displayName           String     @map("display_name") @db.VarChar(255)
  vendorCategory        String     @map("vendor_category") @db.VarChar(100)
  country               String?    @db.VarChar(100)
  address               String?
  primaryEmail          String?    @unique @map("primary_email") @db.VarChar(255)
  primaryPhone          String?    @map("primary_phone") @db.VarChar(50)
  taxId                 String?    @map("tax_id") @db.VarChar(100)
  bankAccountRef        String?    @map("bank_account_ref") @db.VarChar(255)
  paymentTermsDays      Int?       @map("payment_terms_days")
  relationshipManagerId String?    @map("relationship_manager_id") @db.Uuid
  status                String     @default("Active") @db.VarChar(20)
  notes                 String?
  createdAt             DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  relationshipManager User? @relation(fields: [relationshipManagerId], references: [id])

  contacts       VendorContact[]
  projectVendors ProjectVendor[]

  @@index([primaryEmail], map: "idx_vendors_email")
  @@index([vendorCategory], map: "idx_vendors_category")
  @@index([status], map: "idx_vendors_status")
  @@index([type], map: "idx_vendors_type")
  @@map("vendors")
}

model VendorContact {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorId           String   @map("vendor_id") @db.Uuid
  userId             String?  @map("user_id") @db.Uuid
  firstName          String   @map("first_name") @db.VarChar(100)
  lastName           String   @map("last_name") @db.VarChar(100)
  jobTitle           String?  @map("job_title") @db.VarChar(100)
  email              String   @db.VarChar(255)
  phone              String?  @db.VarChar(50)
  isPrimary          Boolean  @default(false) @map("is_primary")
  isInvoicingContact Boolean  @default(false) @map("is_invoicing_contact")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz

  vendor Vendor @relation(fields: [vendorId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([vendorId], map: "idx_vendor_contacts_vendor")
  @@index([userId], map: "idx_vendor_contacts_user")
  @@index([email], map: "idx_vendor_contacts_email")
  @@map("vendor_contacts")
}

model ProjectVendor {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId         String       @map("project_id") @db.Uuid
  vendorId          String       @map("vendor_id") @db.Uuid
  engagementType    String       @map("engagement_type") @db.VarChar(50)
  agreedCost        Decimal?     @map("agreed_cost") @db.Decimal(12, 2)
  currency          String       @default("USD") @db.VarChar(10)
  internalContactId String?      @map("internal_contact_id") @db.Uuid
  startDate         DateTime?    @map("start_date") @db.Date
  endDate           DateTime?    @map("end_date") @db.Date
  status            String       @default("Active") @db.VarChar(20)
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz

  project         Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendor          Vendor  @relation(fields: [vendorId], references: [id])
  internalContact User?   @relation(fields: [internalContactId], references: [id])

  @@unique([projectId, vendorId], map: "uq_project_vendor")
  @@index([projectId], map: "idx_project_vendors_project")
  @@index([vendorId], map: "idx_project_vendors_vendor")
  @@map("project_vendors")
}

model File {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  path String @db.VarChar

  @@map("file")
}

