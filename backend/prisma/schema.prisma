model HealthRuleConfig {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dimension      String   @db.VarChar(50)
  greenThreshold Decimal  @map("green_threshold") @db.Decimal(10, 4)
  amberThreshold Decimal  @map("amber_threshold") @db.Decimal(10, 4)
  unit           String?  @db.VarChar(20)
  version        String   @db.VarChar(20)
  isActive       Boolean  @default(true) @map("is_active")
  updatedBy      String   @map("updated_by") @db.Uuid
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz

  updater User @relation(fields: [updatedBy], references: [id])

  @@index([dimension, isActive], map: "idx_health_rules_active")
  @@map("health_rule_configs")
}

model KpiSnapshot {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  kpiFamily   String   @map("kpi_family") @db.VarChar(50)
  value       Json
  ragStatus   String   @map("rag_status") @db.VarChar(10)
  ruleVersion String   @map("rule_version") @db.VarChar(20)
  capturedAt  DateTime @default(now()) @map("captured_at") @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId], map: "idx_kpi_project")
  @@index([kpiFamily], map: "idx_kpi_family")
  @@index([capturedAt], map: "idx_kpi_captured")
  @@map("kpi_snapshots")
}

model GeneratedReport {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId     String?   @map("project_id") @db.Uuid
  reportType    String    @map("report_type") @db.VarChar(50)
  version       Int       @default(1)
  status        String    @default("Draft") @db.VarChar(20)
  generatedBy   String?   @map("generated_by") @db.Uuid
  approvedBy    String?   @map("approved_by") @db.Uuid
  s3PdfKey      String?   @map("s3_pdf_key") @db.VarChar(512)
  s3DocxKey     String?   @map("s3_docx_key") @db.VarChar(512)
  dataSnapshot  Json?     @map("data_snapshot")
  generatedAt   DateTime  @default(now()) @map("generated_at") @db.Timestamptz
  approvedAt    DateTime? @map("approved_at") @db.Timestamptz
