generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUM TYPES
// ─────────────────────────────────────────

enum PriorityLevel {
  Low
  Medium
  High
  Critical
}

enum ProjectStatus {
  Draft
  Active
  On_Hold         @map("On Hold")
  At_Risk         @map("At Risk")
  Pending_Closure @map("Pending Closure")
  Closed
  Cancelled
}

enum TaskStatus {
  To_Do                @map("To Do")
  In_Progress          @map("In Progress")
  Submitted_for_Review @map("Submitted for Review")
  Approved
  Rework
  Done
}

enum PhaseStatus {
  Planned
  Active
  Completed
  On_Hold @map("On Hold")
}

enum EngagementType {
  Advisory
  Assessment
  Implementation
  Managed_Service    @map("Managed Service")
  Training
  Staff_Augmentation @map("Staff Augmentation")
}

enum BillingModel {
  Fixed_Price        @map("Fixed Price")
  Retainer
  SLA_Based          @map("SLA-Based")
  Time_and_Materials @map("Time & Materials")
}


enum PartyType {
  Company
  Individual
}

// ─────────────────────────────────────────
// DOMAIN 0: REFERENCE / LOOKUPS
// ─────────────────────────────────────────

model Department {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String   @unique @db.VarChar(30)
  name      String   @unique @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  projects  Project[]
  employees Employee[]

  @@map("departments")
}

model SecurityDomain {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String   @unique @db.VarChar(40)
  name      String   @db.VarChar(150)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  projectDomains ProjectDomain[]

  @@map("security_domains")
}

model Currency {
  code             String  @id @db.VarChar(3)
  name             String  @db.VarChar(100)
  number           String  @db.VarChar(3)
  subunitsInUnit   Int     @map("subunits_in_unit")
  symbol           String? @db.VarChar(10)

  @@map("currencies")
}


// ─────────────────────────────────────────
// DOMAIN 1: AUTH & RBAC
// ─────────────────────────────────────────

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entraObjectId String    @unique @map("entra_object_id") @db.VarChar(128)
  email         String    @unique @db.VarChar(255)
  displayName   String    @map("display_name") @db.VarChar(255)
  roleId        Int       @map("role_id")
  isActive      Boolean   @default(true) @map("is_active")
  isExternal    Boolean   @default(false) @map("is_external")
  lastLogin     DateTime? @map("last_login") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  role Role @relation(fields: [roleId], references: [id])

  sessions                  Session[]
  auditLogs                 AuditLog[]
  createdProjects           Project[]            @relation("ProjectCreatedBy")
  primaryProjects           Project[]            @relation("ProjectPrimaryPM")
  secondaryProjects         Project[]            @relation("ProjectSecondaryPM")
  ownedTasks                Task[]               @relation("TaskOwner")
  taskComments              TaskComment[]
  uploadedAttachments       TaskAttachment[]
  engineerProgressUpdates   TaskProgressUpdate[] @relation("ProgressEngineer")
  reviewedProgressUpdates   TaskProgressUpdate[] @relation("ProgressReviewer")
  employees                 Employee?
  approvedAllocations       Allocation[]
  timesheetApprovals        TimesheetApproval[]
  approvedBudgets           ProjectBudget[]
  approvedRevisions         BudgetRevision[]
  resolvedSyncs             FailedSyncRecord[]
  ownedRisks                Risk[]
  ownedIssues               Issue[]
  raisedIssues              Issue[]              @relation("IssueRaiser")
  notifications             Notification[]
  alertAcks                 AlertEvent[]
  ownedEscalations          CustomerEscalation[]
  escalationComms           EscalationCommunication[]
  ownedActionPoints         ActionPoint[]
  authoredLessons           LessonsLearned[]
  updatedHealthRules        HealthRuleConfig[]
  generatedReports          GeneratedReport[]    @relation("ReportGenerator")
  approvedReports           GeneratedReport[]    @relation("ReportApprover")
  createdSchedules          ReportSchedule[]
  resolvedDataFlags         DataQualityFlag[]
  organizedMeetings         Meeting[]
  meetingAttendees          MeetingAttendee[]
  ownedMeetingItems         MeetingItem[]
  reviewedMoms              MomDocument[]
  momAcks                   MomAcknowledgement[]
  grantedExternalAccess     ExternalAccessGrant[] @relation("AccessGrantor")
  receivedExternalAccess    ExternalAccessGrant[] @relation("AccessUser")
  authoredWorkspaceThreads  WorkspaceThread[]
  authoredWorkspacePosts    WorkspaceThreadPost[]
  uploadedWorkspaceDocs     WorkspaceDocument[]
  offlineSyncQueue          OfflineSyncQueue[]
  pushSubscriptions         PushSubscription[]
  approvedCharters          ProjectCharter[]
  approvedSows              SowDocument[]
  createdTemplates          ProjectTemplate[]
  checklistOwners           ChecklistItem[]      @relation("ChecklistOwner")
  checklistSigners          ChecklistItem[]      @relation("ChecklistSigner")
  ownedSlaTickets           SlaTicket[]
  loggedTicketTimerEvents   TicketTimerEvent[]
  authoredTicketUpdates     TicketCustomerUpdate[]
  managedCustomers          Customer[]
  customerContacts          CustomerContact[]
  managedVendors            Vendor[]
  vendorContacts            VendorContact[]
  projectVendorContacts     ProjectVendor[]

  @@index([entraObjectId], map: "idx_users_entra")
  @@index([email], map: "idx_users_email")
  @@index([roleId], map: "idx_users_role")
  @@map("users")
}

model Role {
  id         Int      @id @default(autoincrement())
  code       String   @unique @db.VarChar(50)
  label      String   @db.VarChar(100)
  isExternal Boolean  @default(false) @map("is_external")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  users                   User[]
  rolePermissions         RolePermission[]
  alertRuleRecipients     AlertRuleRecipient[]
  reportScheduleRecipients ReportScheduleRecipient[]

  @@map("roles")
}

// Canonical permission catalog — one row per module+action pair.
model Permission {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  module String @db.VarChar(100)
  action String @db.VarChar(50)

  rolePermissions RolePermission[]

  @@unique([module, action], map: "uq_permissions_module_action")
  @@index([module, action], map: "idx_permissions_module_action")
  @@map("permissions")
}

// Join table: which role has which permission, with scope overrides.
model RolePermission {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId       Int     @map("role_id")
  permissionId String  @map("permission_id") @db.Uuid
  recordScope  String? @map("record_scope") @db.VarChar(50)
  fieldScope   Json?   @map("field_scope")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId], map: "uq_role_permissions_role_permission")
  @@index([roleId], map: "idx_role_permissions_role")
  @@index([permissionId], map: "idx_role_permissions_permission")
  @@map("role_permissions")
}

model Session {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @unique @map("refresh_token_hash") @db.VarChar(255)
  ipAddress        String?   @map("ip_address") // Prisma maps Inet -> String
  userAgent        String?   @map("user_agent")
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz
  isBreakGlass     Boolean   @default(false) @map("is_break_glass")
  breakGlassReason String?   @map("break_glass_reason") @db.VarChar(500)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId], map: "idx_sessions_user")
  @@index([refreshTokenHash], map: "idx_sessions_token")
  @@map("sessions")
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  action     String   @db.VarChar(50)
  objectType String   @map("object_type") @db.VarChar(100)
  objectId   String?  @map("object_id") @db.Uuid
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address")
  isExternal Boolean  @default(false) @map("is_external")
  breakGlassAction Boolean @default(false) @map("break_glass_action")
  source     String?  @db.VarChar(50)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [actorId], references: [id])

  @@index([actorId], map: "idx_audit_actor")
  @@index([objectType], map: "idx_audit_object_type")
  @@index([createdAt], map: "idx_audit_created")
  @@index([objectType, objectId], map: "idx_audit_object")
  @@index([breakGlassAction], map: "idx_audit_break_glass")
  @@map("audit_logs")
}

// Long-term storage for audit rows moved past retention (same shape as AuditLog).
model AuditLogArchive {
  id               String   @id @db.Uuid
  actorId          String?  @map("actor_id") @db.Uuid
  action           String   @db.VarChar(50)
  objectType       String   @map("object_type") @db.VarChar(100)
  objectId         String?  @map("object_id") @db.Uuid
  oldValue         Json?    @map("old_value")
  newValue         Json?    @map("new_value")
  ipAddress        String?  @map("ip_address")
  isExternal       Boolean  @default(false) @map("is_external")
  breakGlassAction Boolean  @default(false) @map("break_glass_action")
  source           String?  @db.VarChar(50)
  createdAt        DateTime @map("created_at") @db.Timestamptz
  archivedAt       DateTime @default(now()) @map("archived_at") @db.Timestamptz

  @@index([actorId], map: "idx_audit_archive_actor")
  @@index([createdAt], map: "idx_audit_archive_created")
  @@index([archivedAt], map: "idx_audit_archive_archived")
  @@map("audit_logs_archive")
}

// Singleton platform settings (one row, id = "default").
model AppSetting {
  id                            String    @id @default("default") @db.VarChar(32)
  auditRetentionMonths          Int       @default(12) @map("audit_retention_months")
  auditExportMaxRows            Int       @default(10000) @map("audit_export_max_rows")
  auditExportExcelJsonCellLimit Int       @default(30000) @map("audit_export_excel_json_cell_limit")
  auditExportPdfJsonLimit       Int       @default(800) @map("audit_export_pdf_json_limit")
  auditArchiveEnabled           Boolean   @default(true) @map("audit_archive_enabled")
  lastAuditArchiveAt            DateTime? @map("last_audit_archive_at") @db.Timestamptz
  lastAuditArchiveCount         Int       @default(0) @map("last_audit_archive_count")
  updatedAt                     DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  updatedById                   String?   @map("updated_by_id") @db.Uuid

  @@map("app_settings")
}

model Notification {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  eventType        String    @map("event_type") @db.VarChar(50)
  title            String    @db.VarChar(255)
  body             String
  payload          Json      @default("{}")
  sourceObjectType String?   @map("source_object_type") @db.VarChar(100)
  sourceObjectId   String?   @map("source_object_id") @db.Uuid
  readAt           DateTime? @map("read_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user       User                   @relation(fields: [userId], references: [id])
  deliveries NotificationDelivery[]

  @@index([userId, readAt], map: "idx_notifications_user_read")
  @@index([userId, createdAt(sort: Desc)], map: "idx_notifications_user_created")
  @@map("notifications")
}

model NotificationDelivery {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  notificationId String    @map("notification_id") @db.Uuid
  channel        String    @db.VarChar(20)
  status         String    @default("queued") @db.VarChar(20)
  error          String?
  retryCount     Int       @default(0) @map("retry_count")
  sentAt         DateTime? @map("sent_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId], map: "idx_notification_deliveries_notification")
  @@index([status], map: "idx_notification_deliveries_status")
  @@map("notification_deliveries")
}

// ─────────────────────────────────────────
// DOMAIN 2: PROJECTS & TASKS
// ─────────────────────────────────────────

model Project {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String         @db.VarChar(255)
  objective         String
  departmentId      String         @map("department_id") @db.Uuid
  customerId        String         @map("customer_id") @db.Uuid
  engagementType    EngagementType @map("engagement_type")
  billingModel      BillingModel   @map("billing_model")
  priority          PriorityLevel  @default(Medium)
  startDate         DateTime       @map("start_date") @db.Date
  endDate           DateTime       @map("end_date") @db.Date
  baselineStartDate DateTime?      @map("baseline_start_date") @db.Date
  baselineEndDate   DateTime?      @map("baseline_end_date") @db.Date
  actualStartDate   DateTime?      @map("actual_start_date") @db.Date
  actualEndDate     DateTime?      @map("actual_end_date") @db.Date
  value             Decimal?       @db.Decimal(15, 2)
  currency          String         @default("USD") @db.VarChar(10)
  primaryPmId       String         @map("primary_pm_id") @db.Uuid
  secondaryPmId     String?        @map("secondary_pm_id") @db.Uuid
  status            ProjectStatus  @default(Draft)
  crmOpportunityId  String?        @map("crm_opportunity_id") @db.Uuid
  templateId        String?        @map("template_id") @db.Uuid
  createdBy         String         @map("created_by") @db.Uuid
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  department     Department       @relation(fields: [departmentId], references: [id])
  customer       Customer         @relation(fields: [customerId], references: [id])
  primaryPm      User             @relation("ProjectPrimaryPM", fields: [primaryPmId], references: [id])
  secondaryPm    User?            @relation("ProjectSecondaryPM", fields: [secondaryPmId], references: [id])
  crmOpportunity CrmOpportunity?  @relation(fields: [crmOpportunityId], references: [id])
  template       ProjectTemplate? @relation(fields: [templateId], references: [id])
  creator        User             @relation("ProjectCreatedBy", fields: [createdBy], references: [id])

  projectDomains        ProjectDomain[]
  phases                ProjectPhase[]
  milestones            ProjectMilestone[]
  tasks                 Task[]
  allocations           Allocation[]
  timesheets            Timesheet[]
  projectBudget         ProjectBudget?
  employeeCosts         EmployeeCost[]
  invoices              Invoice[]
  risks                 Risk[]
  issues                Issue[]
  customerEscalations   CustomerEscalation[]
  actionPoints          ActionPoint[]
  lessonsLearned        LessonsLearned[]
  kpiSnapshots          KpiSnapshot[]
  generatedReports      GeneratedReport[]
  reportSchedules       ReportSchedule[]
  meetings              Meeting[]
  externalAccessGrants  ExternalAccessGrant[]
  workspaceThreads      WorkspaceThread[]
  workspaceDocuments    WorkspaceDocument[]
  projectCharters       ProjectCharter[]
  sowDocuments          SowDocument[]
  closureChecklist      ClosureChecklist?
  slaTickets            SlaTicket[]
  projectVendors        ProjectVendor[]

  @@index([customerId], map: "idx_projects_customer")
  @@index([primaryPmId], map: "idx_projects_pm")
  @@index([status], map: "idx_projects_status")
  @@index([departmentId], map: "idx_projects_dept")
  @@index([engagementType], map: "idx_projects_engagement")
  @@map("projects")
}

model ProjectDomain {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String @map("project_id") @db.Uuid
  domainId  String @map("domain_id") @db.Uuid

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  domain  SecurityDomain @relation(fields: [domainId], references: [id])

  @@unique([projectId, domainId], map: "uq_project_domain")
  @@index([domainId], map: "idx_project_domains_domain")
  @@map("project_domains")
}

model ProjectPhase {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String      @map("project_id") @db.Uuid
  name        String      @db.VarChar(255)
  description String?
  orderIndex  Int         @default(0) @map("order_index")
  startDate   DateTime    @map("start_date") @db.Date
  endDate     DateTime    @map("end_date") @db.Date
  status      PhaseStatus @default(Planned)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  project    Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestones ProjectMilestone[]
  tasks      Task[]

  @@index([projectId], map: "idx_phases_project")
  @@map("project_phases")
}

model ProjectMilestone {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String        @map("project_id") @db.Uuid
  phaseId    String?       @map("phase_id") @db.Uuid
  title      String        @db.VarChar(255)
  targetDate DateTime      @map("target_date") @db.Date
  weight     Decimal?      @db.Decimal(5, 2)
  status     String        @default("Pending") @db.VarChar(30)
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz

  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase     ProjectPhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  invoices  Invoice[]

  @@index([projectId], map: "idx_milestones_project")
  @@index([phaseId], map: "idx_milestones_phase")
  @@map("project_milestones")
}

model Task {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId        String        @map("project_id") @db.Uuid
  parentTaskId     String?       @map("parent_task_id") @db.Uuid
  phaseId          String?       @map("phase_id") @db.Uuid
  title            String        @db.VarChar(255)
  description      String?
  priority         PriorityLevel @default(Medium)
  ownerId          String?       @map("owner_id") @db.Uuid
  startDate        DateTime?     @map("start_date") @db.Date
  endDate          DateTime?     @map("end_date") @db.Date
  baselineStart    DateTime?     @map("baseline_start") @db.Date
  baselineEnd      DateTime?     @map("baseline_end") @db.Date
  actualStart      DateTime?     @map("actual_start") @db.Date
  actualEnd        DateTime?     @map("actual_end") @db.Date
  effortHours      Int?          @map("effort_hours")
  progressApproved Int           @default(0) @map("progress_approved")
  progressPending  Int           @default(0) @map("progress_pending")
  status           TaskStatus    @default(To_Do)
  isOnCriticalPath Boolean       @default(false) @map("is_on_critical_path")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentTask  Task?   @relation("SubTasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subTasks    Task[]  @relation("SubTasks")
  phase       ProjectPhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  owner       User?   @relation("TaskOwner", fields: [ownerId], references: [id])

  comments          TaskComment[]
  attachments       TaskAttachment[]
  dependenciesAsPre TaskDependency[] @relation("DependencyPredecessor")
  dependenciesAsSuc TaskDependency[] @relation("DependencySuccessor")
  progressUpdates   TaskProgressUpdate[]
  timesheets        Timesheet[]

  @@index([projectId], map: "idx_tasks_project")
  @@index([ownerId], map: "idx_tasks_owner")
  @@index([parentTaskId], map: "idx_tasks_parent")
  @@index([status], map: "idx_tasks_status")
  @@index([phaseId], map: "idx_tasks_phase")
  @@map("tasks")
}

model TaskComment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId     String   @map("task_id") @db.Uuid
  authorId   String   @map("author_id") @db.Uuid
  body       String
  isInternal Boolean  @default(true) @map("is_internal")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([taskId], map: "idx_task_comments_task")
  @@map("task_comments")
}

model TaskAttachment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId     String   @map("task_id") @db.Uuid
  uploadedBy String   @map("uploaded_by") @db.Uuid
  s3Key      String   @map("s3_key") @db.VarChar(512)
  filename   String   @db.VarChar(255)
  mimeType   String?  @map("mime_type") @db.VarChar(100)
  sizeBytes  BigInt?  @map("size_bytes")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploader User @relation(fields: [uploadedBy], references: [id])

  @@index([taskId], map: "idx_task_attachments_task")
  @@map("task_attachments")
}

model TaskDependency {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  predecessorId String   @map("predecessor_id") @db.Uuid
  successorId   String   @map("successor_id") @db.Uuid
  depType       String   @map("dep_type") @db.VarChar(10) // FS, SS, FF, SF
  lagDays       Int      @default(0) @map("lag_days")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  predecessor Task @relation("DependencyPredecessor", fields: [predecessorId], references: [id], onDelete: Cascade)
  successor   Task @relation("DependencySuccessor", fields: [successorId], references: [id], onDelete: Cascade)

  @@unique([predecessorId, successorId], map: "uq_task_dependency")
  @@index([predecessorId], map: "idx_deps_predecessor")
  @@index([successorId], map: "idx_deps_successor")
  @@map("task_dependencies")
}

model TaskProgressUpdate {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId          String    @map("task_id") @db.Uuid
  engineerId      String    @map("engineer_id") @db.Uuid
  progressPercent Int       @map("progress_percent")
  hoursSpent      Decimal   @map("hours_spent") @db.Decimal(6, 2)
  comment         String?
  s3EvidenceKey   String?   @map("s3_evidence_key") @db.VarChar(512)
  evidenceFiles   Json?     @map("evidence_files")
  status          String    @default("Pending") @db.VarChar(20)
  reviewedBy      String?   @map("reviewed_by") @db.Uuid
  reviewReason    String?   @map("review_reason")
  reviewedAt      DateTime? @map("reviewed_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  task     Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  engineer User  @relation("ProgressEngineer", fields: [engineerId], references: [id])
  reviewer User? @relation("ProgressReviewer", fields: [reviewedBy], references: [id])

  @@index([taskId], map: "idx_progress_task")
  @@index([engineerId], map: "idx_progress_engineer")
  @@index([status], map: "idx_progress_status")
  @@map("task_progress_updates")
}

// ─────────────────────────────────────────
// DOMAIN 3: RESOURCE & TIME
// ─────────────────────────────────────────

model Employee {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kekaEmployeeId String   @unique @map("keka_employee_id") @db.VarChar(100)
  userId         String?  @unique @map("user_id") @db.Uuid
  name           String   @db.VarChar(255)
  email          String   @db.VarChar(255)
  departmentId   String   @map("department_id") @db.Uuid
  designation    String   @db.VarChar(100)
  managerId      String?  @map("manager_id") @db.Uuid
  weeklyHours    Decimal  @default(40) @map("weekly_hours") @db.Decimal(5, 2)
  isActive       Boolean  @default(true) @map("is_active")
  syncedAt       DateTime @map("synced_at") @db.Timestamptz
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user       User?       @relation(fields: [userId], references: [id])
  department Department  @relation(fields: [departmentId], references: [id])
  manager    Employee?   @relation("EmployeeManager", fields: [managerId], references: [id])
  subordinates Employee[] @relation("EmployeeManager")

  allocations   Allocation[]
  leaveRecords  LeaveRecord[]
  timesheets    Timesheet[]
  employeeCosts EmployeeCost[]

  @@index([kekaEmployeeId], map: "idx_employees_keka_id")
  @@index([departmentId], map: "idx_employees_dept")
  @@index([managerId], map: "idx_employees_manager")
  @@map("employees")
}

model Allocation {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId String    @map("employee_id") @db.Uuid
  projectId  String    @map("project_id") @db.Uuid
  role       String    @db.VarChar(100)
  percent    Decimal?  @db.Decimal(5, 2)
  hours      Decimal?  @db.Decimal(7, 2)
  startDate  DateTime  @map("start_date") @db.Date
  endDate    DateTime? @map("end_date") @db.Date
  status     String    @default("Active") @db.VarChar(20)
  approvedBy String?   @map("approved_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  employee Employee @relation(fields: [employeeId], references: [id])
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approver User?    @relation(fields: [approvedBy], references: [id])

  @@index([employeeId], map: "idx_allocations_employee")
  @@index([projectId], map: "idx_allocations_project")
  @@index([status], map: "idx_allocations_status")
  @@map("allocations")
}

model LeaveRecord {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  leaveDate  DateTime @map("leave_date") @db.Date
  leaveType  String   @map("leave_type") @db.VarChar(50)
  isApproved Boolean  @default(false) @map("is_approved")
  kekaRef    String?  @map("keka_ref") @db.VarChar(100)
  syncedAt   DateTime @map("synced_at") @db.Timestamptz

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, leaveDate], map: "uq_leave_employee_date")
  @@index([employeeId], map: "idx_leave_employee")
  @@index([leaveDate], map: "idx_leave_date")
  @@map("leave_records")
}

model Timesheet {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId    String   @map("employee_id") @db.Uuid
  projectId     String   @map("project_id") @db.Uuid
  taskId        String   @map("task_id") @db.Uuid
  workDate      DateTime @map("work_date") @db.Date
  regularHours  Decimal  @default(0) @map("regular_hours") @db.Decimal(5, 2)
  overtimeHours Decimal  @default(0) @map("overtime_hours") @db.Decimal(5, 2)
  notes         String?
  isBillable    Boolean  @default(true) @map("is_billable")
  status        String   @default("Draft") @db.VarChar(20)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  employee Employee @relation(fields: [employeeId], references: [id])
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  approvals TimesheetApproval[]

  @@unique([employeeId, workDate, taskId], map: "uq_timesheet_entry")
  @@index([employeeId], map: "idx_timesheets_employee")
  @@index([projectId], map: "idx_timesheets_project")
  @@index([workDate], map: "idx_timesheets_date")
  @@index([status], map: "idx_timesheets_status")
  @@map("timesheets")
}

model TimesheetApproval {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  timesheetId  String    @map("timesheet_id") @db.Uuid
  reviewerId   String    @map("reviewer_id") @db.Uuid
  decision     String    @db.VarChar(20)
  comment      String?
  kekaSyncedAt DateTime? @map("keka_synced_at") @db.Timestamptz
  kekaSyncRef  String?   @map("keka_sync_ref") @db.VarChar(100)
  decidedAt    DateTime  @default(now()) @map("decided_at") @db.Timestamptz

  timesheet Timesheet @relation(fields: [timesheetId], references: [id])
  reviewer  User      @relation(fields: [reviewerId], references: [id])

  @@index([timesheetId], map: "idx_ts_approvals_timesheet")
  @@index([reviewerId], map: "idx_ts_approvals_reviewer")
  @@map("timesheet_approvals")
}

model KekaSyncLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.VarChar(100)
  direction  String   @db.VarChar(10)
  status     String   @db.VarChar(20)
  payload    Json?
  errorMsg   String?  @map("error_msg")
  retryCount Int      @default(0) @map("retry_count")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([entityType], map: "idx_keka_log_entity_type")
  @@index([status], map: "idx_keka_log_status")
  @@index([createdAt], map: "idx_keka_log_created")
  @@map("keka_sync_log")
}

// ─────────────────────────────────────────
// DOMAIN 4: FINANCE & INTEGRATIONS
// ─────────────────────────────────────────

model ProjectBudget {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId      String       @unique @map("project_id") @db.Uuid
  baselineAmount Decimal      @map("baseline_amount") @db.Decimal(15, 2)
  currency       String       @default("USD") @db.VarChar(10)
  approvedBy     String       @map("approved_by") @db.Uuid
  approvedAt     DateTime     @map("approved_at") @db.Timestamptz
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approver User    @relation(fields: [approvedBy], references: [id])

  revisions BudgetRevision[]
  lineItems BudgetLineItem[]

  @@map("project_budgets")
}

model BudgetRevision {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  budgetId      String    @map("budget_id") @db.Uuid
  revisedAmount Decimal   @map("revised_amount") @db.Decimal(15, 2)
  reason        String
  approvedBy    String?   @map("approved_by") @db.Uuid
  approvedAt    DateTime? @map("approved_at") @db.Timestamptz
  status        String    @default("Pending") @db.VarChar(20)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  budget   ProjectBudget @relation(fields: [budgetId], references: [id])
  approver User?         @relation(fields: [approvedBy], references: [id])

  @@index([budgetId], map: "idx_budget_revisions_budget")
  @@map("budget_revisions")
}

model BudgetLineItem {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  budgetId  String   @map("budget_id") @db.Uuid
  category  String   @db.VarChar(50)
  itemName  String   @map("item_name") @db.VarChar(255)
  planned   Decimal  @db.Decimal(12, 2)
  actual    Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  budget ProjectBudget @relation(fields: [budgetId], references: [id])

  @@index([budgetId], map: "idx_line_items_budget")
  @@map("budget_line_items")
}

model EmployeeCost {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId    String   @map("employee_id") @db.Uuid
  projectId     String   @map("project_id") @db.Uuid
  periodYear    Int      @map("period_year")
  periodMonth   Int      @map("period_month")
  ratePerHour   Decimal  @map("rate_per_hour") @db.Decimal(10, 4)
  regularHours  Decimal  @map("regular_hours") @db.Decimal(7, 2)
  overtimeHours Decimal  @default(0) @map("overtime_hours") @db.Decimal(7, 2)
  totalCost     Decimal  @map("total_cost") @db.Decimal(12, 2)
  computedAt    DateTime @map("computed_at") @db.Timestamptz

  employee Employee @relation(fields: [employeeId], references: [id])
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([employeeId, projectId, periodYear, periodMonth], map: "uq_emp_cost_period")
  @@index([employeeId], map: "idx_emp_costs_employee")
  @@index([projectId], map: "idx_emp_costs_project")
  @@map("employee_costs")
}

model Invoice {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId          String       @map("project_id") @db.Uuid
  zohoInvoiceId      String       @unique @map("zoho_invoice_id") @db.VarChar(100)
  invoiceNumber      String       @map("invoice_number") @db.VarChar(100)
  amount             Decimal      @db.Decimal(15, 2)
  currency           String       @default("USD") @db.VarChar(10)
  dueDate            DateTime     @map("due_date") @db.Date
  collectionDate     DateTime?    @map("collection_date") @db.Date
  status             String       @db.VarChar(20)
  matchedMilestoneId String?      @map("matched_milestone_id") @db.Uuid
  discrepancyNote    String?      @map("discrepancy_note")
  syncedAt           DateTime     @map("synced_at") @db.Timestamptz
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz

  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestone ProjectMilestone? @relation(fields: [matchedMilestoneId], references: [id], onDelete: SetNull)

  @@index([projectId], map: "idx_invoices_project")
  @@index([zohoInvoiceId], map: "idx_invoices_zoho")
  @@index([status], map: "idx_invoices_status")
  @@index([dueDate], map: "idx_invoices_due")
  @@map("invoices")
}

model CrmOpportunity {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  zohoOpportunityId String    @unique @map("zoho_opportunity_id") @db.VarChar(100)
  expectedRevenue   Decimal?  @map("expected_revenue") @db.Decimal(15, 2)
  stage             String?   @db.VarChar(100)
  lastWritebackAt   DateTime? @map("last_writeback_at") @db.Timestamptz
  syncedAt          DateTime  @map("synced_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz

  projects     Project[]
  sowDocuments SowDocument[]

  @@index([zohoOpportunityId], map: "idx_crm_opps_zoho")
  @@map("crm_opportunities")
}

model FailedSyncRecord {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  integration   String    @db.VarChar(50)
  entityType    String    @map("entity_type") @db.VarChar(50)
  entityId      String?   @map("entity_id") @db.VarChar(100)
  direction     String    @db.VarChar(10)
  payload       Json?
  errorMsg      String    @map("error_msg")
  retryCount    Int       @default(0) @map("retry_count")
  isResolved    Boolean   @default(false) @map("is_resolved")
  resolvedBy    String?   @map("resolved_by") @db.Uuid
  resolvedAt    DateTime? @map("resolved_at") @db.Timestamptz
  lastAttempted DateTime  @map("last_attempted") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  resolver User? @relation(fields: [resolvedBy], references: [id])

  @@index([integration], map: "idx_failed_sync_integration")
  @@index([isResolved], map: "idx_failed_sync_resolved")
  @@map("failed_sync_records")
}

