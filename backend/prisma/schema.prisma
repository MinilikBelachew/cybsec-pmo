model Risk {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId          String    @map("project_id") @db.Uuid
  category           String    @db.VarChar(100)
  impact             Int
  likelihood         Int
  score              Int
  ownerId            String    @map("owner_id") @db.Uuid
  mitigationPlan     String?   @map("mitigation_plan")
  targetDate         DateTime? @map("target_date") @db.Date
  residualImpact     Int?      @map("residual_impact")
  residualLikelihood Int?      @map("residual_likelihood")
  residualRating     Int?      @map("residual_rating")
  status             String    @default("Open") @db.VarChar(30)
  ruleVersion        String?   @map("rule_version") @db.VarChar(20)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner   User    @relation(fields: [ownerId], references: [id])

  @@index([projectId], map: "idx_risks_project")
  @@index([score], map: "idx_risks_score")
  @@index([status], map: "idx_risks_status")
  @@map("risks")
}

model Issue {
  id                     String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId              String        @map("project_id") @db.Uuid
  title                  String        @db.VarChar(255)
  priority               PriorityLevel
  ownerId                String        @map("owner_id") @db.Uuid
  dueDate                DateTime      @map("due_date") @db.Date
  expectedResolutionDate DateTime?     @map("expected_resolution_date") @db.Date
  status                 String        @default("Open") @db.VarChar(30)
  resolutionNote         String?       @map("resolution_note")
  s3EvidenceKey          String?       @map("s3_evidence_key") @db.VarChar(512)
  raisedBy               String        @map("raised_by") @db.Uuid
  createdAt              DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner   User    @relation(fields: [ownerId], references: [id])
  raiser  User    @relation("IssueRaiser", fields: [raisedBy], references: [id])

  @@index([projectId], map: "idx_issues_project")
  @@index([ownerId], map: "idx_issues_owner")
  @@index([status], map: "idx_issues_status")
  @@index([dueDate], map: "idx_issues_due")
  @@map("issues")
}

model AlertRule {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType          String   @map("event_type") @db.VarChar(100)
  thresholdConfig    Json     @map("threshold_config")
  channels           String[]
  reminderCadenceHrs Int      @default(24) @map("reminder_cadence_hrs")
  escalationDelayHrs Int      @default(48) @map("escalation_delay_hrs")
  escalationRole     String   @map("escalation_role") @db.VarChar(50)
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  recipients AlertRuleRecipient[]
  events     AlertEvent[]

  @@map("alert_rules")
}

model AlertRuleRecipient {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ruleId    String @map("rule_id") @db.Uuid
  roleId  Int @map("role_id")

  rule AlertRule @relation(fields: [ruleId], references: [id])
  role Role      @relation(fields: [roleId], references: [id])

  @@unique([ruleId, roleId], map: "uq_alert_rule_recipient")
  @@map("alert_rule_recipients")
}

model AlertEvent {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ruleId           String    @map("rule_id") @db.Uuid
  objectType       String    @map("object_type") @db.VarChar(100)
  objectId         String?   @map("object_id") @db.Uuid
  channel          String    @db.VarChar(20)
  deliveryStatus   String    @map("delivery_status") @db.VarChar(20)
  acknowledgedBy   String?   @map("acknowledged_by") @db.Uuid
  escalationLevel  Int       @default(0) @map("escalation_level")
  firedAt          DateTime  @default(now()) @map("fired_at") @db.Timestamptz
  ackedAt          DateTime? @map("acked_at") @db.Timestamptz
  nextReminderAt   DateTime? @map("next_reminder_at") @db.Timestamptz

  rule  AlertRule @relation(fields: [ruleId], references: [id])
  acker User?     @relation(fields: [acknowledgedBy], references: [id])

  @@index([ruleId], map: "idx_alert_events_rule")
  @@index([objectType], map: "idx_alert_events_object_type")
  @@index([deliveryStatus], map: "idx_alert_events_status")
  @@map("alert_events")
}

model CustomerEscalation {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId         String    @map("project_id") @db.Uuid
  customerId        String    @map("customer_id") @db.Uuid
  severity          String    @db.VarChar(20)
  slaTargetHrs      Int       @map("sla_target_hrs")
  ownerId           String    @map("owner_id") @db.Uuid
  status            String    @default("Open") @db.VarChar(30)
  resolutionSummary String?   @map("resolution_summary")
  slaBreached       Boolean   @default(false) @map("sla_breached")
  closedAt          DateTime? @map("closed_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])
  owner    User     @relation(fields: [ownerId], references: [id])

  communications EscalationCommunication[]

  @@index([projectId], map: "idx_escalations_project")
  @@index([status], map: "idx_escalations_status")
  @@index([severity], map: "idx_escalations_severity")
  @@map("customer_escalations")
}

model EscalationCommunication {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  escalationId String   @map("escalation_id") @db.Uuid
  channel      String   @db.VarChar(30)
  content      String
  loggedBy     String   @map("logged_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  escalation CustomerEscalation @relation(fields: [escalationId], references: [id])
  logger     User               @relation(fields: [loggedBy], references: [id])

  @@index([escalationId], map: "idx_esc_comms_escalation")
  @@map("escalation_communications")
}

model ActionPoint {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceType  String        @map("source_type") @db.VarChar(50)
  sourceId    String        @map("source_id") @db.Uuid
  projectId   String?       @map("project_id") @db.Uuid
  ownerId     String        @map("owner_id") @db.Uuid
  title       String        @db.VarChar(255)
  dueDate     DateTime      @map("due_date") @db.Date
  priority    PriorityLevel
  status      String        @default("Open") @db.VarChar(20)
  closureNote String?       @map("closure_note")
  closedAt    DateTime?     @map("closed_at") @db.Timestamptz
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner   User     @relation(fields: [ownerId], references: [id])

  @@index([ownerId], map: "idx_actions_owner")
  @@index([projectId], map: "idx_actions_project")
  @@index([sourceType, sourceId], map: "idx_actions_source")
  @@index([dueDate], map: "idx_actions_due")
  @@index([status], map: "idx_actions_status")
  @@map("action_points")
}

model LessonsLearned {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId      String?  @map("project_id") @db.Uuid
  category       String   @db.VarChar(100)
  description    String
  recommendation String
  tags           String[]
  authorId       String   @map("author_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User     @relation(fields: [authorId], references: [id])

  @@index([category], map: "idx_lessons_category")
  @@index([projectId], map: "idx_lessons_project")
  @@map("lessons_learned")
}

