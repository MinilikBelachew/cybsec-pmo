<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>{{title}}</title>
</head>
<body style="font-family: Arial, sans-serif; line-height: 1.5; color: #111827;">
  <p>Hi {{displayName}},</p>
  <h2 style="margin: 0 0 12px;">{{title}}</h2>
  <p style="margin: 0 0 16px;">{{body}}</p>
  <p style="margin: 0;">
    <a href="{{link}}" style="color: #2563eb; text-decoration: none;">{{actionTitle}}</a>
  </p>
  <p style="color: #6b7280; font-size: 12px; margin-top: 24px;">Sent by {{app_name}}.</p>
</body>
</html>
