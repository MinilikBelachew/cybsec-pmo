<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{title}}</title>
</head>
<body style="margin:0;padding:0;background-color:#f3f4f6;font-family:Arial,Helvetica,sans-serif;line-height:1.5;color:#111827;">
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color:#f3f4f6;padding:24px 12px;">
    <tr>
      <td align="center">
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width:560px;background-color:#ffffff;border-radius:8px;overflow:hidden;border:1px solid #e5e7eb;">
          <tr>
            <td style="background-color:#008ecc;padding:18px 24px;color:#ffffff;font-size:16px;font-weight:700;letter-spacing:0.02em;">
              {{app_name}}
            </td>
          </tr>
          <tr>
            <td style="padding:28px 24px 8px;font-size:15px;color:#374151;">
              Hi {{displayName}},
            </td>
          </tr>
          <tr>
            <td style="padding:0 24px 12px;font-size:22px;font-weight:700;color:#111827;line-height:1.3;">
              {{title}}
            </td>
          </tr>
          <tr>
            <td style="padding:0 24px 24px;font-size:15px;color:#4b5563;">
              {{body}}
            </td>
          </tr>
          <tr>
            <td style="padding:0 24px 28px;" align="left">
              <a href="{{link}}" style="display:inline-block;padding:12px 20px;background-color:#008ecc;color:#ffffff;text-decoration:none;font-size:14px;font-weight:600;border-radius:6px;">
                {{actionTitle}}
              </a>
            </td>
          </tr>
          <tr>
            <td style="padding:16px 24px;background-color:#f9fafb;border-top:1px solid #e5e7eb;font-size:12px;color:#9ca3af;">
              Sent by {{app_name}}. If the button does not work, open this link:<br />
              <a href="{{link}}" style="color:#008ecc;word-break:break-all;">{{link}}</a>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
