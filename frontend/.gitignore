# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.prod

# vercel
.vercel
*.zip
*.xlsx

# typescript
*.tsbuildinfo
next-env.d.ts

# E2E Playwright test artifacts (phase-separated)
# /test-results/
# /test-results-phase1/
# /test-results-phase2/
# /playwright-report/
# /playwright-report-phase1/
# /playwright-report-phase2/
